# Oref Alert Proxy URL
OREF_PROXY_URL=http://localhost:8764

# How often to check the proxy (seconds)
POLL_INTERVAL=3

# ── MQTT (Smart Lights) ─────────────────────────────────────────────────────
MQTT_BROKER=10.0.0.4
MQTT_PORT=1883
# MQTT_USERNAME=
# MQTT_PASSWORD=

# Comma-separated MQTT topics for color-switchable lights
# Each light gets a JSON payload: {"color": {"r": 255, "g": 0, "b": 0}}
# Adjust the topic format to match your setup (Zigbee2MQTT, Tasmota, etc.)
MQTT_LIGHT_TOPICS=zigbee2mqtt/alert-light-1/set,zigbee2mqtt/alert-light-2/set

# Restore lights to off after all-clear fades (seconds, 0 = never)
LIGHT_RESTORE_AFTER=120

# ── Snapcast TTS ────────────────────────────────────────────────────────────
SNAPCAST_FIFO=/tmp/snapfifo

# Enable/disable TTS announcements
TTS_ENABLED=true

# Minimum seconds between repeated TTS announcements of the same type
TTS_COOLDOWN=60

# ── Monitored Area (for local alerts) ───────────────────────────────────────
# Hebrew area name to monitor for local early-warning/active/all-clear
LOCAL_AREA=ירושלים - דרום

# ── OpenAI TTS (for generating audio files) ─────────────────────────────────
# Only needed if you want to regenerate the pre-recorded audio
# OPENAI_API_KEY=your-key-here
